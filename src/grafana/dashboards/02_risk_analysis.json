                "value": {
                  "fixedColor": "#e74c3c",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "К выполнению"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#95a5a6",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "На ревью"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#9b59b6",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      }
    },
    {
      "id": 8,
      "title": "Статистика документов по статусам",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "datasource": {
        "type": "postgres",
        "uid": "corptracker-pg"
      },
      "targets": [
        {
