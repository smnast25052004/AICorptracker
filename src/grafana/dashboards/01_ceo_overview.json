    {
      "id": 7,
      "title": "Здоровье стратегических целей",
      "type": "table",
      "gridPos": {
        "h": 10,
        "w": 14,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "corptracker-pg"
      },
      "targets": [
        {
          "rawSql": "SELECT g.title AS \"Цель\", CASE g.status WHEN 'ON_TRACK' THEN '🟢 В норме' WHEN 'AT_RISK' THEN '🟡 Под угрозой' WHEN 'CRITICAL' THEN '🔴 Критический' WHEN 'COMPLETED' THEN '🔵 Завершён' ELSE g.status::text END AS \"Статус\", ROUND(g.risk_score * 100) || '%' AS \"Риск\", ROUND(g.progress) || '%' AS \"Прогресс\", g.priority::text AS \"Приоритет\", g.owner AS \"Владелец\", (SELECT COUNT(*) FROM projects p WHERE p.goal_id = g.id) AS \"Проектов\", (SELECT COUNT(*) FROM tasks t JOIN projects p ON t.project_id = p.id WHERE p.goal_id = g.id) AS \"Задач\", (SELECT COUNT(*) FROM tasks t JOIN projects p ON t.project_id = p.id WHERE p.goal_id = g.id AND t.status = 'BLOCKED') AS \"Блокеров\" FROM strategic_goals g ORDER BY g.risk_score DESC;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Цель"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 280
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": true,
          "reducer": [
            "sum"
          ],
          "countRows": true
        }
      }
    },
