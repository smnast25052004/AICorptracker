    {
      "id": 15,
      "title": "🔔 Последние AI-рекомендации",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "corptracker-pg"
      },
      "targets": [
        {
          "rawSql": "SELECT CASE r.priority WHEN 'URGENT' THEN '🔴 СРОЧНО' WHEN 'HIGH' THEN '🟠 Высокий' WHEN 'MEDIUM' THEN '🟡 Средний' ELSE '🟢 Низкий' END AS \"Приоритет\", r.title AS \"Рекомендация\", g.title AS \"Цель\", r.action AS \"Действие\", r.status AS \"Статус\", TO_CHAR(r.created_at, 'DD.MM.YYYY HH24:MI') AS \"Дата\" FROM recommendations r JOIN strategic_goals g ON r.goal_id = g.id WHERE r.status = 'ACTIVE' ORDER BY CASE r.priority WHEN 'URGENT' THEN 0 WHEN 'HIGH' THEN 1 WHEN 'MEDIUM' THEN 2 ELSE 3 END, r.created_at DESC LIMIT 15;",
          "format": "table",
          "refId": "A"
        }
