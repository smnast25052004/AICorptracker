    {
      "id": 6,
      "title": "Средний риск",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 19,
        "y": 2
      },
      "datasource": {
        "type": "postgres",
        "uid": "corptracker-pg"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(risk_score) * 100) AS \"Средний риск (%)\" FROM strategic_goals WHERE risk_score > 0;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#27ae60",
                "value": null
              },
              {
                "color": "#f39c12",
                "value": 30
              },
              {
                "color": "#e67e22",
                "value": 55
              },
              {
                "color": "#e74c3c",
                "value": 75
              }
            ]
          }
        }
